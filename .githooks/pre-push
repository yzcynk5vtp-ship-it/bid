#!/usr/bin/env bash
# .githooks/pre-push — local guard for pushes that could damage main's history.
#
# Activation: run `scripts/install-githooks.sh` once.
#
# What this blocks:
#   1. Non-fast-forward push to main/master/release/*.
#   2. Push with too many root commits.
#   3. agent/* 分支首次 push 提醒使用统一 PR 脚本。
#
# What this warns:
#   4. Gitee Token 未设置时提醒（创建 PR 需要）。

set -euo pipefail

remote="${1:-origin}"
PROTECTED_BRANCHES_REGEX='^refs/heads/(main|master|release/.+)$'
MAX_ROOTS=4

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_DIR="$(cd "$HOOK_DIR/../scripts" && pwd)"
GITEE_TOKEN_SCRIPT="$SCRIPT_DIR/gitee-token.sh"

# ── Gitee Token 提醒（不阻断 push）────────────────────────────────────────
remote_url="$(git remote get-url "$remote" 2>/dev/null || true)"
case "$remote_url" in
  *gitee.com*)
    token="$("$GITEE_TOKEN_SCRIPT" 2>/dev/null)" || token=""
    if [[ -z "$token" ]]; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  💡 提示: Gitee Token 未设置                              ║"
      echo "║                                                          ║"
      echo "║  Push 走 SSH 不受影响，但创建 PR 需要 Token。             ║"
      echo "║                                                          ║"
      echo "║  export GITEE_TOKEN='your_token'                          ║"
      echo "║  # 或写入 credential store:                               ║"
      echo "║  echo 'https://user:token@gitee.com' >> ~/.git-credentials║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""
    fi
    ;;
esac

# ── agent/* 分支 PR 脚本提醒 ──────────────────────────────────────────────
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  branch="${local_ref#refs/heads/}"
  if [[ "$branch" == agent/* ]] && [[ "${remote_sha}" == "0000000000000000000000000000000000000000" ]]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  💡 创建 PR 请使用统一脚本                                 ║"
    echo "║                                                          ║"
    echo "║    ./scripts/pr-create.sh \"feat: 标题\" [/path/body.md]    ║"
    echo "║                                                          ║"
    echo "║  禁止手动 gh pr create 或网页操作。                       ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    break
  fi
done

# ── 保护分支强制 push 拦截 ──────────────────────────────────────────────
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "${remote_ref}" =~ ${PROTECTED_BRANCHES_REGEX} ]]; then
        if [ "${remote_sha}" = "0000000000000000000000000000000000000000" ]; then
            continue
        fi
        if ! git merge-base --is-ancestor "${remote_sha}" "${local_sha}" 2>/dev/null; then
            if [ "${FORCE_PUSH_OK:-0}" != "1" ]; then
                echo "::pre-push:: refusing non-fast-forward push to ${remote_ref}." >&2
                exit 1
            fi
        fi
        root_count=$(git rev-list --max-parents=0 "${local_sha}" | wc -l | tr -d ' ')
        if [ "${root_count}" -gt "${MAX_ROOTS}" ]; then
            echo "::pre-push:: refusing push to ${remote_ref}: HEAD has ${root_count} root commits." >&2
            exit 1
        fi
    fi
done

# ── 质量门禁 ────────────────────────────────────────────────────────────
if [ "${PRE_PUSH_GATE:-1}" = "1" ] && [ -x "$SCRIPT_DIR/pre-push-gate.sh" ]; then
  if ! bash "$SCRIPT_DIR/pre-push-gate.sh"; then
    echo "::pre-push:: 质量门禁未通过。修复后重试，或 PRE_PUSH_GATE=0 git push 跳过。" >&2
    exit 1
  fi
fi

exit 0
