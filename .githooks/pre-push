#!/usr/bin/env bash
# .githooks/pre-push — local guard for pushes that could damage main's history.
#
# Activation: this hook only runs if the repo is configured to use .githooks/ as
# its hooks directory. Run `scripts/install-githooks.sh` once to enable it, or
# manually: `git config core.hooksPath .githooks`.
#
# What this blocks:
#   1. Any --force / --force-with-lease push to main, master, or release/* refs.
#   2. Pushes to main where HEAD has more root commits than the documented
#      ratchet (see .github/workflows/branch-history-guard.yml).
#   3. Gitee 远端 push 时未设置 GITEE_TOKEN（阻止 push）
#   4. 所有 agent/* 分支 push 时检查是否通过 pr-create.sh 创建 PR（温和提醒）
#
# Context: ericforai/bidding#224 documents the root-commit issue. This hook is
# the developer-local mirror of the CI workflow — same check, earlier signal.
#
# Inputs: git invokes the hook with `<remote> <url>` on argv and a list of
#   `<local_ref> <local_sha> <remote_ref> <remote_sha>` lines on stdin.

set -euo pipefail

remote="${1:-origin}"
PROTECTED_BRANCHES_REGEX='^refs/heads/(main|master|release/.+)$'
MAX_ROOTS=4

# ==============================================================================
# 前置门禁 A: 远端凭证检查
# ==============================================================================
remote_url="$(git remote get-url "$remote" 2>/dev/null || true)"

case "$remote_url" in
  *gitee.com*)
    if [[ -z "${GITEE_TOKEN:-}" && -z "${GITEE_PUSH_OK:-}" ]]; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  ❌ GITEE_TOKEN 未设置，拒绝 push                         ║"
      echo "║                                                          ║"
      echo "║  当前远端是 Gitee（$remote_url）"
      echo "║  必须设置 GITEE_TOKEN 才能推送代码到远端。               ║"
      echo "║                                                          ║"
      echo "║  设置方式:                                                ║"
      echo "║    export GITEE_TOKEN='your_personal_access_token'        ║"
      echo "║                                                          ║"
      echo "║  申请 Token: https://gitee.com/profile/personal_tokens    ║"
      echo "║                                                          ║"
      echo "║  跳过检查: GITEE_PUSH_OK=1 git push ...                   ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
    ;;
esac

# ==============================================================================
# 前置门禁 B: GitHub 远端 gh 登录检查
# ==============================================================================
case "$remote_url" in
  *github.com*)
    if [[ "${PRE_PUSH_SKIP_GH_CHECK:-0}" != "1" ]] && ! gh auth status &>/dev/null; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  ⚠️  GitHub CLI (gh) 未登录                               ║"
      echo "║                                                          ║"
      echo "║  当前远端是 GitHub，但 gh 未通过认证。                    ║"
      echo "║  提交代码后无法通过 gh 创建 PR。                          ║"
      echo "║                                                          ║"
      echo "║  请执行: gh auth login                                    ║"
      echo "║  或设置: export GH_TOKEN=ghp_xxx                          ║"
      echo "║                                                          ║"
      echo "║  跳过检查: PRE_PUSH_SKIP_GH_CHECK=1 git push ...          ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
    ;;
esac

# ==============================================================================
# 前置门禁 C+D: agent/* 分支检查
#   C: 首次 push 时提醒使用统一脚本创建 PR
#   D: 禁止推送已合入 main 的分支，防止 PR 合并后继续推送导致代码丢失
# ==============================================================================
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  branch="${local_ref#refs/heads/}"
  if [[ "$branch" == agent/* ]]; then
    # 门禁 C: 首次 push 时提醒使用统一脚本
    if [[ "${remote_sha}" == "0000000000000000000000000000000000000000" ]]; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  💡 提示: 创建 PR 请使用统一脚本                          ║"
      echo "║                                                          ║"
      echo "║  分支: $branch"
      echo "║                                                          ║"
      echo "║  请通过 scripts/pr-create.sh 创建 PR，不要手动执行:      ║"
      echo "║    gh pr create                           ← 禁止         ║"
      echo "║    git push origin ... + 网页操作         ← 禁止          ║"
      echo "║                                                          ║"
      echo "║  正确用法:                                                ║"
      echo "║    ./scripts/pr-create.sh \"feat: 你的标题\" /path/body.md  ║"
      echo "║                                                          ║"
      echo "║  该脚本会自动处理 GitHub / Gitee 的差异。                 ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""
    fi

    # 门禁 D: 禁止推送已合入 main 的分支
    # 防止 PR 合并后继续往同一分支推送新提交，导致代码未合入
    if git branch -r --merged origin/main 2>/dev/null | grep -qwE "origin/${branch}$"; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  ❌ 拒绝推送到已合入 main 的分支                           ║"
      echo "╠══════════════════════════════════════════════════════════════╣"
      echo "║  分支: $branch                                              ║"
      echo "║  该分支已合入 main，继续推送会导致新提交不在 PR 中。       ║"
      echo "║                                                              ║"
      echo "║  正确做法:                                                   ║"
      echo "║    1. 切回锚点分支: git checkout agent/<name>-init         ║"
      echo "║    2. 同步 main: git pull origin main --rebase             ║"
      echo "║    3. 开新分支: ./scripts/agent-start-task.sh \\            ║"
      echo "║                  <name> <task> origin/main --in-place       ║"
      echo "║                                                              ║"
      echo "║  如需紧急修复，请使用 --force 强制推送（不推荐）：          ║"
      echo "║    git push origin $branch --force-with-lease               ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
  fi
done

# 1) refuse force pushes to protected branches.
#    差异化策略:
#      - Gitee (origin) main: 绝对禁止 force push（Gitee 是唯一真值，只能通过 PR 合入）
#      - GitHub (github) main: 允许 force-with-lease（单向镜像，Gitee → GitHub）
#      - 其他远端 + 其他受保护分支: 默认禁止
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "${remote_ref}" =~ ${PROTECTED_BRANCHES_REGEX} ]]; then
        # New ref creation (remote_sha is all zeros) is allowed.
        if [ "${remote_sha}" = "0000000000000000000000000000000000000000" ]; then
            continue
        fi
        # Non-fast-forward detection: remote_sha must be an ancestor of local_sha.
        if ! git merge-base --is-ancestor "${remote_sha}" "${local_sha}" 2>/dev/null; then
            # 判断是否为允许的特例：GitHub remote 的 main 分支（单向镜像）
            is_github_mirror=0
            case "$remote_url" in
              *github.com*|*github-bid*)
                # 只有 main 分支且是 Gitee→GitHub 镜像方向才允许
                if [[ "${remote_ref}" == "refs/heads/main" ]]; then
                    is_github_mirror=1
                fi
                ;;
            esac

            if [ "${FORCE_PUSH_OK:-0}" != "1" ] && [ "$is_github_mirror" != "1" ]; then
                echo "" >&2
                echo "╔══════════════════════════════════════════════════════════════╗" >&2
                echo "║  ❌ 禁止非快进推送（force push）到 ${remote_ref} ║" >&2
                echo "╠══════════════════════════════════════════════════════════════╣" >&2
                echo "║  远端: $remote" >&2
                echo "║  远端 SHA: ${remote_sha:0:12}" >&2
                echo "║  本地 SHA: ${local_sha:0:12}" >&2
                echo "║                                                          ║" >&2
                if [[ "${remote_ref}" == "refs/heads/main" ]]; then
                    echo "║  原因: 重写 main 分支历史会覆盖他人的提交。            ║" >&2
                    echo "║  正确做法:                                              ║" >&2
                    echo "║    1. git pull --rebase  （同步到最新）                 ║" >&2
                    echo "║    2. 解决冲突                                          ║" >&2
                    echo "║    3. git push          （正常推送）                    ║" >&2
                else
                    echo "║  原因: 重写受保护分支历史。                            ║" >&2
                fi
                echo "╚══════════════════════════════════════════════════════════════╝" >&2
                echo "" >&2
                exit 1
            fi
            if [ "$is_github_mirror" = "1" ]; then
                echo "::pre-push:: GitHub main 单向镜像，允许 force-with-lease 推送。" >&2
            else
                echo "::pre-push:: FORCE_PUSH_OK=1 set, allowing non-fast-forward push to ${remote_ref}." >&2
            fi
        fi

        # 2) root-commit ratchet: refuse pushes that would grow the root count.
        root_count=$(git rev-list --max-parents=0 "${local_sha}" | wc -l | tr -d ' ')
        if [ "${root_count}" -gt "${MAX_ROOTS}" ]; then
            echo "::pre-push:: refusing push to ${remote_ref}: HEAD has ${root_count} root commits, ratchet allows ${MAX_ROOTS}." >&2
            echo "  This usually means a history rewrite (filter-repo, checkout --orphan, replace --graft) added a new disconnected segment." >&2
            echo "  See ericforai/bidding#224 before proceeding." >&2
            exit 1
        fi
    fi
done

# 3) Quality gate — runs before every push (skip with PRE_PUSH_GATE=0)
if [ "${PRE_PUSH_GATE:-1}" = "1" ] && [ -x "$(dirname "$0")/../scripts/pre-push-gate.sh" ]; then
  if ! bash "$(dirname "$0")/../scripts/pre-push-gate.sh"; then
    echo ""
    echo "::pre-push:: 质量门禁未通过。修复后重试，或 PRE_PUSH_GATE=0 git push 跳过。" >&2
    exit 1
  fi
fi

exit 0
