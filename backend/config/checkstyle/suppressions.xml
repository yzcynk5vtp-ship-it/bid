<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <suppress files=".*/src/test/java/.*" checks=".*"/>
    <!-- DTOs use Lombok; field-level Javadoc adds noise without value -->
    <suppress files=".*/dto/.*\.java" checks="JavadocVariable|JavadocType|JavadocMethod|MissingJavadocMethod|JavadocPackage|JavadocStyle|MagicNumber|LineLength|FinalParameters"/>
    <!-- JPA entities: Lombok-generated, field names document themselves -->
    <suppress files=".*/persistence/entity/.*\.java" checks="JavadocVariable|MissingJavadocMethod|DesignForExtension"/>
    <!-- JPA repositories: Spring Data interfaces -->
    <suppress files=".*/persistence/repository/.*\.java" checks="JavadocMethod|JavadocType"/>
    <!-- Shared infrastructure utilities -->
    <suppress files=".*/shared/infrastructure/.*\.java" checks="JavadocVariable|MissingJavadocMethod|DesignForExtension|MagicNumber"/>

    <!-- Config classes use Lombok; field-level Javadoc and magic numbers are noise -->
    <suppress files=".*/config/.*\.java" checks="JavadocVariable|JavadocType|JavadocMethod|MissingJavadocMethod|JavadocPackage|JavadocStyle|MagicNumber|LineLength|FinalParameters"/>
    <!-- Domain policies: pure logic, magic numbers are domain constants -->
    <suppress files=".*/domain/.*\.java" checks="MagicNumber|JavadocVariable|JavadocMethod|MissingJavadocMethod|DesignForExtension"/>
    <!-- Infrastructure adapters: controllers and clients -->
    <suppress files=".*/infrastructure/.*\.java" checks="JavadocVariable|MissingJavadocMethod|DesignForExtension"/>
    <!-- Application services: orchestration, Spring-managed singletons -->
    <suppress files=".*/application/.*\.java" checks="JavadocVariable|MissingJavadocMethod|DesignForExtension|FinalParameters|HiddenField"/>

    <!--
      Javadoc 历史债 blanket（37k+ pre-existing）。
      宽泛压制 src/main/java 下所有 Javadoc* 检查，让全量扫描和 IDE 不再被噪音淹没。
      受保护核心也包含在内（避免 strict gate 因本次改动而变红）。
      未来收紧：编辑本行 files 正则 carve-out 子树（如 ai/core），按 QUALITY_GATE_GUIDE L3/A 类处理。
      完整背景、权衡、操作步骤见 implementation-notes.md（Checkstyle Javadoc 37k 历史债 + 修直过程） + docs/code-formatting.md + backend/QUALITY_GATE_GUIDE.md。
      历史参考：conductor/archive/checkstyle_zero_violation_20260425（曾尝试 mass placeholder，已否定）。
    -->
    <suppress files=".*/src/main/java/.*\.java" checks="JavadocVariable|JavadocType|JavadocMethod|MissingJavadocMethod|JavadocPackage|JavadocStyle"/>
</suppressions>
