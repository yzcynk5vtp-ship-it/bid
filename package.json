{
  "name": "xiyu-bid-poc",
  "version": "1.0.3",
  "description": "西域数智化投标管理平台POC",
  "type": "module",
  "scripts": {
    "dev": "bash ./scripts/dev-frontend.sh",
    "dev:api": "bash ./scripts/dev-frontend.sh",
    "dev:all": "bash ./start.sh",
    "dev:default": "bash ./scripts/dev-default.sh",
    "dev:stable:start": "bash ./scripts/dev-services.sh start",
    "dev:stable:stop": "bash ./scripts/dev-services.sh stop",
    "dev:stable:restart": "bash ./scripts/dev-services.sh restart",
    "dev:stable:status": "bash ./scripts/dev-services.sh status",
    "dev:stable:healthcheck": "bash ./scripts/dev-services.sh healthcheck",
    "dev:stable:logs": "bash ./scripts/dev-services.sh logs",
    "dev:docker:start": "bash ./scripts/local-docker-stack.sh dev",
    "dev:docker:up": "bash ./scripts/local-docker-stack.sh up",
    "dev:docker:stop": "bash ./scripts/local-docker-stack.sh stop",
    "dev:docker:status": "bash ./scripts/local-docker-stack.sh status",
    "dev:docker:logs": "bash ./scripts/local-docker-stack.sh logs",
    "dev:stable:watch:start": "bash ./scripts/dev-services.sh watch-start",
    "dev:stable:watch:stop": "bash ./scripts/dev-services.sh watch-stop",
    "dev:stable:watch:status": "bash ./scripts/dev-services.sh watch-status",
    "dev:stable:daemon:install": "bash ./scripts/dev-services-launchd.sh install",
    "dev:stable:daemon:install:mysql": "BACKEND_PROFILE=dev,mysql bash ./scripts/dev-services-launchd.sh install",
    "dev:stable:daemon:install:e2e": "BACKEND_PROFILE=e2e bash ./scripts/dev-services-launchd.sh install",
    "dev:stable:daemon:start": "bash ./scripts/dev-services-launchd.sh start",
    "dev:stable:daemon:stop": "bash ./scripts/dev-services-launchd.sh stop",
    "dev:stable:daemon:restart": "bash ./scripts/dev-services-launchd.sh restart",
    "dev:stable:daemon:status": "bash ./scripts/dev-services-launchd.sh status",
    "dev:stable:daemon:logs": "bash ./scripts/dev-services-launchd.sh logs",
    "dev:stable:daemon:uninstall": "bash ./scripts/dev-services-launchd.sh uninstall",
    "agent:morning": "bash ./scripts/agent-dev.sh morning",
    "agent:up": "bash ./scripts/agent-dev.sh up",
    "agent:restart": "bash ./scripts/agent-dev.sh restart",
    "agent:stop": "bash ./scripts/agent-dev.sh stop",
    "agent:status": "bash ./scripts/agent-dev.sh status",
    "agent:logs": "bash ./scripts/agent-dev.sh logs",
    "agent:lock-check": "node scripts/check-agent-locks.mjs",
    "agent:lock-check:changed": "node scripts/check-agent-locks.mjs --changed-only",
    "agent:lock-acquire": "node scripts/manage-agent-locks.mjs acquire",
    "agent:lock-release": "node scripts/manage-agent-locks.mjs release",
    "agent:lock-renew": "node scripts/agent-lock-renew.mjs",
    "agent:health-check": "node scripts/agent-health-check.mjs",
    "agent:pre-push-dry-run": "bash scripts/pre-push-dry-run.sh",
    "test:agent-start-task-contract": "bash scripts/test/agent-start-task-dryrun-contract.sh",
    "agent:lock-cleanup": "node scripts/check-agent-locks.mjs --clean-stale",
    "dev:mode": "bash ./scripts/dev-current-mode.sh",
    "ci:local": "bash scripts/local-ci.sh full",
    "ci:local:quick": "bash scripts/local-ci.sh quick",
    "ci:local:release": "bash scripts/local-ci.sh release",
    "sync:version": "node scripts/sync-version.mjs",
    "check:version-sync": "node scripts/check-version-sync.mjs",
    "check:front-data-boundaries": "node scripts/check-front-data-boundaries.mjs",
    "check:doc-governance": "node scripts/check-doc-governance.mjs",
    "check:line-budgets": "node scripts/check-line-budgets.mjs",
    "check:line-budgets:staged": "node scripts/check-line-budgets.mjs --staged",
    "check:task-status-literal": "node scripts/check-task-status-literal.mjs",
    "check:token-governance": "node scripts/check-token-coverage.mjs --fail-on-hex --max-hex-total=1100",
    "check:token-governance:warn": "node scripts/check-token-coverage.mjs --fail-on-hex --max-hex-total=1100",
    "check:token-governance:delta": "node scripts/check-token-coverage.mjs --delta --fail-on-hex --max-hex=5",
    "wiki:ingest": "node scripts/wiki-ingest.mjs",
    "wiki:build": "node scripts/wiki-build.mjs",
    "wiki:check": "node scripts/wiki-check.mjs",
    "db:generate-rollback": "node scripts/generate-flyway-rollback-scripts.mjs",
    "db:dev-repair": "bash scripts/dev-flyway-repair.sh",
    "check:blueprint-gaps": "node scripts/check-blueprint-gaps.mjs",
    "check:blueprint-fields": "node scripts/check-blueprint-fields.mjs",
    "build": "npm run check:version-sync && npm run check:front-data-boundaries && npm run check:doc-governance && npm run check:task-status-literal && npm run check:token-governance && npm run check:token-governance:delta && npm run check:blueprint-gaps && npm run check:blueprint-fields && npm run check:line-budgets && vite build",
    "build:api": "vite build --mode api",
    "preview": "vite preview",
    "test:e2e": "npx playwright test --config playwright.config.js",
    "test:e2e:commercial": "npx playwright test commercial-main-flow --config playwright.config.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "perf:sales200": "k6 run scripts/performance/sales-200.k6.js",
    "check-docs": "bash scripts/check-doc-consistency.sh",
    "lint": "eslint src e2e",
    "lint:fix": "eslint src e2e --fix",
    "postinstall": "bash scripts/install-githooks.sh",
    "ci:pre-pr": "bash scripts/ci-pre-pr.sh",
    "gitee:pr-list": "GITEE_TOKEN=${GITEE_TOKEN} ./scripts/gitee-pr-helper.sh list",
    "gitee:pr-create": "GITEE_TOKEN=${GITEE_TOKEN} ./scripts/gitee-pr-helper.sh create",
    "gitee:pr-merge": "GITEE_TOKEN=${GITEE_TOKEN} ./scripts/gitee-pr-helper.sh merge",
    "gitee:auto-merge": "GITEE_TOKEN=${GITEE_TOKEN} ./scripts/gitee-auto-merge-gate.sh",
    "test:dev-services": "bats scripts/test/dev-services-contract.bats"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
