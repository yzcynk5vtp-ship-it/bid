.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
  font-size: 28rpx;
}

.detail-content {
  padding: 20rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.tender-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-PENDING_ASSIGNMENT { background-color: #E6A23C; color: #fff; }
.status-TRACKING { background-color: #67C23A; color: #fff; }
.status-BIDDING { background-color: #409EFF; color: #fff; }
.status-WON { background-color: #67C23A; color: #fff; }
.status-LOST { background-color: #909399; color: #fff; }
.status-ABANDONED { background-color: #F56C6C; color: #fff; }

.info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.info-value {
  font-size: 30rpx;
  color: #333;
}

.info-value.deadline {
  color: #E6A23C;
}

.prediction-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  color: #fff;
}

.prediction-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.prediction-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.prediction-confidence {
  font-size: 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.prediction-date {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.prediction-note {
  font-size: 26rpx;
  opacity: 0.8;
}

.ai-score-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.ai-score-main {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-value {
  font-size: 60rpx;
  font-weight: bold;
  color: #409EFF;
}

.score-label {
  font-size: 24rpx;
  color: #999;
}

.ai-risk {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.risk-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.risk-value {
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.risk-LOW { background-color: #67C23A; color: #fff; }
.risk-MEDIUM { background-color: #E6A23C; color: #fff; }
.risk-HIGH { background-color: #F56C6C; color: #fff; }

.description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin: 0 10rpx;
}

.action-btn.primary {
  background-color: #409EFF;
  color: #fff;
}

.action-btn.secondary {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}
